*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Local config
.env
.env.*
*.local

# Generated temp media
tmp/
temp/
*.mov
*.MOV
*.mp4
*.m4v
*.heic
*.heif

# Keep intentional test fixtures under docs or fixtures if needed.
!docs/**/*.mp4
!fixtures/**/*.mp4

